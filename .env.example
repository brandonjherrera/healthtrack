# ============================================================================
# HealthTrack API — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://healthtrack:your_password_here@localhost:5432/healthtrack

# AI Vision — for food photo scanning (pick one or both)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_VISION_MODEL=claude-sonnet-4-6    # or gpt-4o

# Food databases
USDA_API_KEY=your_usda_key_here      # Free at https://fdc.nal.usda.gov/api-key-signup

# Open Food Facts — no API key needed, but set user agent
OFF_USER_AGENT=HealthTrack/0.1.0 (personal use)

# Photo storage — local path on Mac Mini
PHOTO_STORAGE_PATH=./uploads/photos
